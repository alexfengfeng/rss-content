# ============================================
# 大模型配置 (用于AI改写新闻)
# 支持 OpenAI 兼容接口 (DeepSeek, 通义千问, Kimi等)
# ============================================

# LLM API Key
LLM_API_KEY=your_api_key_here

# LLM 模型名称
LLM_MODEL=deepseek-chat

# LLM Base URL (不需要加 /v1)
LLM_BASE_URL=https://api.deepseek.com

# ============================================
# 微信公众号配置
# ============================================

# 微信公众号 API Key (从 wx.limyai.com 获取)
WECHAT_API_KEY=your_wechat_api_key

# 公众号 APPID (可选，不填会自动列出账号选择)
WECHAT_APPID=

# ============================================
# RSSHub 配置
# ============================================

# RSSHub 服务地址
RSSHUB_URL=http://localhost:1200

# ============================================
# 应用配置
# ============================================

# 数据库路径
DB_PATH=./data/news.db

# Web 管理界面端口
WEB_PORT=3000

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 每次抓取的新闻数量限制
FETCH_LIMIT=20

# 定时任务配置 (Cron表达式)
# 默认每2小时抓取一次
FETCH_CRON=0 */2 * * *

# 默认每天上午9点发布
PUBLISH_CRON=0 9 * * *
