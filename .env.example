# ============================================
# 大模型配置 (用于 AI 改写新闻)
# 支持 OpenAI 兼容接口 (DeepSeek, 通义千问，Kimi 等)
# ============================================

# LLM API Key
LLM_API_KEY=your_api_key_here

# LLM 模型名称
LLM_MODEL=deepseek-chat

# LLM Base URL (不需要加 /v1)
LLM_BASE_URL=https://api.deepseek.com

# ============================================
# 微信公众号配置 (官方微信开发者平台)
# ============================================

# 公众号 APPID (从微信公众平台获取)
# 获取方式：登录 https://mp.weixin.qq.com -> 开发 -> 基本配置
WECHAT_APPID=your_appid_here

# 公众号 APPSECRET (从微信公众平台获取)
# 获取方式：登录 https://mp.weixin.qq.com -> 开发 -> 基本配置 -> 生成并重置
WECHAT_APPSECRET=your_appsecret_here

# ============================================
# RSSHub 配置
# ============================================

# RSSHub 服务地址
RSSHUB_URL=http://localhost:1200

# ============================================
# 应用配置
# ============================================

# 数据库路径
DB_PATH=./data/news.db

# Web 管理界面端口
WEB_PORT=3000

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 每次抓取的新闻数量限制
FETCH_LIMIT=20

# 定时任务配置 (Cron 表达式)
# 默认每 2 小时抓取一次
FETCH_CRON=0 */2 * * *

# 默认每天上午 9 点发布
PUBLISH_CRON=0 9 * * *
