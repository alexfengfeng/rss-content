

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">首页</a></li>
      <li class="breadcrumb-item"><a href="/news">新闻管理</a></li>
      <li class="breadcrumb-item active" aria-current="page">新闻详情</li>
    </ol>
  </nav>
</div>

<div class="row g-4">
  <!-- 左侧：原文信息 -->
  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-header bg-light">
        <h5 class="card-title mb-0">
          <i class="bi bi-file-text text-primary me-2"></i>原文信息
        </h5>
      </div>
      <div class="card-body">
        <table class="table table-borderless">
          <tr>
            <td width="100" class="text-muted">ID</td>
            <td>#<%= news.id %></td>
          </tr>
          <tr>
            <td class="text-muted">来源</td>
            <td><span class="badge bg-secondary"><%= news.source_name %></span></td>
          </tr>
          <tr>
            <td class="text-muted">状态</td>
            <td>
              <span class="status-badge status-<%= news.status %>">
                <%= news.status === 'pending' ? '待改写' : '' %>
                <%= news.status === 'rewritten' ? '已改写' : '' %>
                <%= news.status === 'published' ? '已发布' : '' %>
                <%= news.status === 'failed' ? '失败' : '' %>
              </span>
            </td>
          </tr>
          <tr>
            <td class="text-muted">发布时间</td>
            <td><%= news.pub_date || '未知' %></td>
          </tr>
          <tr>
            <td class="text-muted">抓取时间</td>
            <td><%= news.fetched_at %></td>
          </tr>
          <% if (news.rewritten_at) { %>
            <tr>
              <td class="text-muted">改写时间</td>
              <td><%= news.rewritten_at %></td>
            </tr>
          <% } %>
          <% if (news.published_at) { %>
            <tr>
              <td class="text-muted">发布时间</td>
              <td><%= news.published_at %></td>
            </tr>
          <% } %>
          <tr>
            <td class="text-muted">原文链接</td>
            <td>
              <a href="<%= news.link %>" target="_blank" class="text-break">
                <%= news.link %> <i class="bi bi-box-arrow-up-right small"></i>
              </a>
            </td>
          </tr>
        </table>
        
        <hr>
        
        <h6 class="fw-bold mb-3">原标题</h6>
        <p class="fs-5"><%= news.title %></p>
        
        <% if (news.description) { %>
          <h6 class="fw-bold mb-3 mt-4">原文摘要</h6>
          <div class="bg-light p-3 rounded">
            <p class="mb-0 text-muted"><%= news.description %></p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 右侧：改写内容 -->
  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-header bg-light">
        <h5 class="card-title mb-0">
          <i class="bi bi-magic text-info me-2"></i>改写内容
        </h5>
      </div>
      <div class="card-body">
        <% if (news.status === 'pending') { %>
          <div class="text-center py-5">
            <i class="bi bi-magic fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted">此新闻尚未改写</p>
            <button class="btn btn-info text-white" onclick="rewriteNews(<%= news.id %>)">
              <i class="bi bi-magic me-2"></i>立即改写
            </button>
          </div>
        <% } else { %>
          <table class="table table-borderless">
            <tr>
              <td width="100" class="text-muted">改写标题</td>
              <td class="fs-5"><%= news.rewritten_title || '-' %></td>
            </tr>
          </table>
          
          <hr>
          
          <h6 class="fw-bold mb-3">改写正文</h6>
          <div class="bg-light p-3 rounded content-text" style="max-height: 500px; overflow-y: auto;">
            <% if (news.rewritten_content) { %>
              <%- news.rewritten_content.replace(/\n/g, '<br>') %>
            <% } else { %>
              -
            <% } %>
          </div>
          
          <% if (news.status === 'rewritten') { %>
            <div class="d-grid gap-2 mt-4">
              <button class="btn btn-success" onclick="publishNews(<%= news.id %>)">
                <i class="bi bi-send me-2"></i>发布到微信公众号
              </button>
            </div>
          <% } %>
          
          <% if (news.status === 'published') { %>
            <div class="alert alert-success mt-4">
              <i class="bi bi-check-circle me-2"></i>
              已发布到微信公众号
              <% if (news.wechat_media_id) { %>
                <br><small class="text-muted">Media ID: <%= news.wechat_media_id %></small>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- 操作按钮 -->
<div class="action-bar mt-4">
  <a href="/news" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>返回列表
  </a>
  
  <div class="ms-auto">
    <% if (news.status === 'pending') { %>
      <button class="btn btn-info text-white me-2" onclick="rewriteNews(<%= news.id %>)">
        <i class="bi bi-magic me-2"></i>AI 改写
      </button>
    <% } %>
    <% if (news.status === 'rewritten') { %>
      <button class="btn btn-success me-2" onclick="publishNews(<%= news.id %>)">
        <i class="bi bi-send me-2"></i>发布到公众号
      </button>
    <% } %>
    <a href="/news/<%= news.id %>/edit" class="btn btn-warning me-2">
      <i class="bi bi-pencil me-2"></i>编辑
    </a>
    <button class="btn btn-danger" onclick="deleteNews(<%= news.id %>)">
      <i class="bi bi-trash me-2"></i>删除
    </button>
  </div>
</div>

<script>
// AI 改写
async function rewriteNews(newsId) {
  const btn = event.target.closest('button');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>改写中...';
  btn.disabled = true;
  
  try {
    await apiFetch('/api/rewrite', {
      method: 'POST',
      body: JSON.stringify({ newsId })
    });
    showToast('改写成功！', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch (error) {
    btn.innerHTML = originalHtml;
    btn.disabled = false;
  }
}

// 发布到公众号
async function publishNews(newsId) {
  if (!confirm('确定要发布到微信公众号吗？')) return;
  
  const btn = event.target.closest('button');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>发布中...';
  btn.disabled = true;
  
  try {
    await apiFetch('/api/publish', {
      method: 'POST',
      body: JSON.stringify({ newsId })
    });
    showToast('发布成功！', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch (error) {
    btn.innerHTML = originalHtml;
    btn.disabled = false;
  }
}

// 删除新闻
async function deleteNews(newsId) {
  if (!confirm('确定要删除这条新闻吗？此操作不可恢复。')) return;
  
  try {
    await apiFetch('/api/news/' + newsId, { method: 'DELETE' });
    showToast('删除成功！', 'success');
    setTimeout(() => location.href = '/news', 1000);
  } catch (error) {
    console.error(error);
  }
}
</script>

<style>
.spin {
  animation: spin 1s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.content-text {
  line-height: 1.8;
}

.content-text h1,
.content-text h2,
.content-text h3 {
  font-size: 1.25rem;
  margin-top: 1rem;
  margin-bottom: 0.5rem;
}

.content-text p {
  margin-bottom: 1rem;
}
</style>
