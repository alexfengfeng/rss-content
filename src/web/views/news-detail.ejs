<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">首页</a></li>
      <li class="breadcrumb-item"><a href="/news">新闻管理</a></li>
      <li class="breadcrumb-item active" aria-current="page">新闻详情</li>
    </ol>
  </nav>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-header bg-light">
        <h5 class="card-title mb-0">
          <i class="bi bi-file-text text-primary me-2"></i>原始信息
        </h5>
      </div>
      <div class="card-body">
        <table class="table table-borderless">
          <tr><td width="110" class="text-muted">ID</td><td>#<%= news.id %></td></tr>
          <tr><td class="text-muted">来源</td><td><span class="badge bg-secondary"><%= news.source_name %></span></td></tr>
          <tr>
            <td class="text-muted">状态</td>
            <td>
              <span class="status-badge status-<%= news.status %>">
                <%= news.status === 'pending' ? '待改写' : '' %>
                <%= news.status === 'rewritten' ? '已改写' : '' %>
                <%= news.status === 'published' ? '已发布' : '' %>
                <%= news.status === 'failed' ? '失败' : '' %>
              </span>
            </td>
          </tr>
          <tr><td class="text-muted">发布时间</td><td><%= news.pub_date || '未知' %></td></tr>
          <tr><td class="text-muted">抓取时间</td><td><%= news.fetched_at %></td></tr>
          <% if (news.rewritten_at) { %><tr><td class="text-muted">改写时间</td><td><%= news.rewritten_at %></td></tr><% } %>
          <% if (news.published_at) { %><tr><td class="text-muted">发布时间</td><td><%= news.published_at %></td></tr><% } %>
          <tr>
            <td class="text-muted">原文链接</td>
            <td>
              <a href="<%= news.link %>" target="_blank" class="text-break">
                <%= news.link %> <i class="bi bi-box-arrow-up-right small"></i>
              </a>
            </td>
          </tr>
        </table>

        <% if (news.error_message) { %>
          <div class="alert alert-danger mt-3">
            <strong>失败原因</strong>
            <div class="mt-2"><%= news.error_message %></div>
          </div>
        <% } %>

        <hr>

        <h6 class="fw-bold mb-3">原标题</h6>
        <p class="fs-5"><%= news.title %></p>

        <% if (news.description) { %>
          <h6 class="fw-bold mb-3 mt-4">原文摘要</h6>
          <div class="bg-light p-3 rounded">
            <p class="mb-0 text-muted"><%= news.description %></p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-header bg-light">
        <h5 class="card-title mb-0">
          <i class="bi bi-magic text-info me-2"></i>改写内容
        </h5>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">选择改写模板</label>
          <select id="templateId" class="form-control">
            <option value="">默认改写模板</option>
            <% (templates || []).forEach((template) => { %>
              <option value="<%= template.id %>">
                <%= template.name %><%= template.is_default ? '（默认）' : '' %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">选择发布样式模板</label>
          <select id="publishTemplateId" class="form-control">
            <option value="">默认发布样式</option>
            <% (publishTemplates || []).forEach((template) => { %>
              <option value="<%= template.id %>" <%= String(template.id) === String(news.publish_template_id || '') ? 'selected' : '' %>>
                <%= template.name %><%= template.is_default ? '（默认）' : '' %>
              </option>
            <% }); %>
          </select>
          <div class="form-text">改写模板控制提示词，发布样式模板控制正文排版、摘要和封面策略。</div>
        </div>

        <% if (news.status === 'pending' || news.status === 'failed') { %>
          <div class="text-center py-5">
            <i class="bi bi-magic fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted">
              <%= news.status === 'failed' ? '当前任务失败，可重新选择模板后再次改写。' : '这条新闻还没有改写。' %>
            </p>
            <% if (news.status === 'failed') { %>
              <button class="btn btn-warning me-2" onclick="resetFailed(<%= news.id %>, event)">
                <i class="bi bi-arrow-repeat me-2"></i>重置为待改写
              </button>
            <% } %>
            <button class="btn btn-info text-white" onclick="rewriteArticle(<%= news.id %>, event)">
              <i class="bi bi-magic me-2"></i>立即改写
            </button>
          </div>
        <% } else { %>
          <table class="table table-borderless">
            <tr>
              <td width="100" class="text-muted">改写标题</td>
              <td class="fs-5"><%= news.rewritten_title || '-' %></td>
            </tr>
          </table>

          <hr>

          <h6 class="fw-bold mb-3">改写正文</h6>
          <div class="bg-light p-3 rounded content-text" style="max-height: 500px; overflow-y: auto;">
            <% if (news.rewritten_content) { %>
              <% const renderedContent = isHtmlContent(news.rewritten_content) ? news.rewritten_content : news.rewritten_content.replace(/\n/g, '<br>'); %>
              <%- renderedContent %>
            <% } else { %>
              -
            <% } %>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button class="btn btn-info text-white" onclick="rewriteArticle(<%= news.id %>, event)">
              <i class="bi bi-arrow-repeat me-2"></i>按所选模板重新改写
            </button>
            <% if (news.status === 'rewritten') { %>
              <button class="btn btn-success" onclick="publishNews(<%= news.id %>, event)">
                <i class="bi bi-send me-2"></i>发布到微信公众号
              </button>
            <% } %>
          </div>

          <% if (news.status === 'published') { %>
            <div class="alert alert-success mt-4">
              <i class="bi bi-check-circle me-2"></i>已发布到微信公众号
              <% if (news.wechat_media_id) { %>
                <div class="small text-muted mt-2">Media ID: <%= news.wechat_media_id %></div>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="action-bar mt-4">
  <a href="/news" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>返回列表
  </a>
  <div class="ms-auto">
    <a href="/news/<%= news.id %>/edit" class="btn btn-warning me-2">
      <i class="bi bi-pencil me-2"></i>编辑
    </a>
    <button class="btn btn-danger" onclick="deleteNews(<%= news.id %>)">
      <i class="bi bi-trash me-2"></i>删除
    </button>
  </div>
</div>

<script>
function getSelectedTemplateId() {
  return document.getElementById('templateId')?.value || '';
}

function getSelectedPublishTemplateId() {
  return document.getElementById('publishTemplateId')?.value || '';
}

async function rewriteArticle(newsId, clickEvent) {
  const btn = clickEvent.currentTarget;
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>改写中...';
  btn.disabled = true;

  try {
    await apiFetch('/api/rewrite', {
      method: 'POST',
      body: JSON.stringify({
        newsId,
        templateId: getSelectedTemplateId(),
        publishTemplateId: getSelectedPublishTemplateId()
      })
    });
    showToast('改写成功', 'success');
    setTimeout(() => location.reload(), 800);
  } catch (error) {
    btn.innerHTML = originalHtml;
    btn.disabled = false;
  }
}

async function publishNews(newsId, clickEvent) {
  if (!confirm('确定要发布到微信公众号吗？')) return;

  const btn = clickEvent.currentTarget;
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>发布中...';
  btn.disabled = true;

  try {
    await apiFetch('/api/publish', {
      method: 'POST',
      body: JSON.stringify({
        newsId,
        publishTemplateId: getSelectedPublishTemplateId()
      })
    });
    showToast('发布成功', 'success');
    setTimeout(() => location.reload(), 800);
  } catch (error) {
    btn.innerHTML = originalHtml;
    btn.disabled = false;
  }
}

async function resetFailed(newsId, clickEvent) {
  const btn = clickEvent.currentTarget;
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>重置中...';
  btn.disabled = true;

  try {
    await apiFetch(`/api/news/${newsId}/reset`, { method: 'POST' });
    showToast('已重置为待改写', 'success');
    setTimeout(() => location.reload(), 800);
  } catch (error) {
    btn.innerHTML = originalHtml;
    btn.disabled = false;
  }
}

async function deleteNews(newsId) {
  if (!confirm('确定要删除这条新闻吗？此操作不可恢复。')) return;

  try {
    await apiFetch(`/api/news/${newsId}`, { method: 'DELETE' });
    showToast('删除成功', 'success');
    setTimeout(() => {
      location.href = '/news';
    }, 800);
  } catch (error) {
    console.error(error);
  }
}
</script>
