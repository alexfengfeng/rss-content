<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.title ? title : appName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
  <nav class="sidebar">
    <a href="/" class="sidebar-brand">
      <i class="bi bi-newspaper"></i>
      <span><%= appName %></span>
    </a>

    <ul class="nav">
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'dashboard' ? 'active' : '' %>" href="/">
          <i class="bi bi-speedometer2"></i>
          <span>仪表盘</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'news' ? 'active' : '' %>" href="/news">
          <i class="bi bi-file-text"></i>
          <span>新闻管理</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'sources' ? 'active' : '' %>" href="/sources">
          <i class="bi bi-rss"></i>
          <span>信源管理</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'templates' ? 'active' : '' %>" href="/templates">
          <i class="bi bi-file-earmark-text"></i>
          <span>改写模板</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'jobs' ? 'active' : '' %>" href="/jobs">
          <i class="bi bi-list-check"></i>
          <span>任务日志</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= locals.activeTab === 'settings' ? 'active' : '' %>" href="/settings">
          <i class="bi bi-gear"></i>
          <span>系统设置</span>
        </a>
      </li>
    </ul>
  </nav>

  <main class="main-content">
    <%- body %>
  </main>

  <div class="toast-container"></div>
  <script src="/js/app.js"></script>
</body>
</html>
