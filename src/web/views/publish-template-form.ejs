<% const isEdit = !!template; %>

<style>
.preview-shell {
  border: 1px solid #dfe6ef;
  border-radius: 18px;
  background: linear-gradient(180deg, #f7fafc 0%, #eef3f8 100%);
  padding: 18px;
}

.preview-phone {
  width: min(100%, 420px);
  margin: 0 auto;
  border-radius: 28px;
  background: #f5f7fa;
  border: 1px solid #d7dee8;
  box-shadow: 0 18px 50px rgba(31, 41, 55, 0.12);
  overflow: hidden;
}

.preview-statusbar {
  height: 28px;
  background: #101828;
}

.preview-screen {
  padding: 10px;
  background: #f5f7fa;
}

.preview-meta {
  font-size: 12px;
  color: #667085;
  margin-bottom: 10px;
}

.preview-cover {
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 12px;
}

.preview-card {
  border-radius: 18px;
  background: #fff;
  border: 1px solid #e4e7ec;
  padding: 10px;
}

.preview-note {
  font-size: 13px;
  color: #667085;
}

.preview-section-title {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #667085;
  margin: 14px 0 8px;
}

.preview-body-line {
  height: 10px;
  border-radius: 999px;
  background: #e5e7eb;
  margin-bottom: 8px;
}
</style>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">首页</a></li>
      <li class="breadcrumb-item"><a href="/publish-templates">发布样式模板</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= isEdit ? '编辑样式模板' : '新建样式模板' %></li>
    </ol>
  </nav>
  <h1 class="h3 mb-2"><%= isEdit ? '编辑发布样式模板' : '新建发布样式模板' %></h1>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-body">
        <form id="publishTemplateForm">
          <div class="mb-3">
            <label class="form-label">模板名称</label>
            <input type="text" class="form-control" name="name" value="<%= template?.name || '' %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label">模板说明</label>
            <input type="text" class="form-control" name="description" value="<%= template?.description || '' %>">
          </div>

          <div class="mb-3">
            <label class="form-label">样式键</label>
            <select class="form-control" id="styleKey" name="style_key" required>
              <% styleOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= (template?.style_key || 'default_article') === option.value ? 'selected' : '' %>>
                  <%= option.label %>
                </option>
              <% }) %>
            </select>
            <div class="form-text">样式键控制真实发布时的代码渲染逻辑，这里管理的是选择项、说明和适用范围。</div>
          </div>

          <div class="mb-3">
            <label class="form-label">适用范围</label>
            <select class="form-control" name="target_type" required>
              <% targetTypeOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= (template?.target_type || 'all') === option.value ? 'selected' : '' %>>
                  <%= option.label %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="is_enabled" name="is_enabled" <%= template?.is_enabled !== 0 ? 'checked' : '' %>>
            <label class="form-label mb-0" for="is_enabled">启用模板</label>
          </div>

          <div class="form-check mb-4">
            <input class="form-check-input" type="checkbox" id="is_default" name="is_default" <%= template?.is_default ? 'checked' : '' %>>
            <label class="form-label mb-0" for="is_default">设为该范围默认模板</label>
          </div>

          <div class="d-flex gap-2">
            <a href="/publish-templates" class="btn btn-outline-secondary">取消</a>
            <button type="submit" class="btn btn-primary"><%= isEdit ? '保存修改' : '创建样式模板' %></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="content-card">
      <div class="card-header bg-light">
        <h5 class="card-title mb-0">
          <i class="bi bi-phone me-2 text-primary"></i>样式预览
        </h5>
      </div>
      <div class="card-body">
        <p class="preview-note mb-3">
          这里展示的是公众号手机端示例效果，包括封面气质、概述区和正文层级。切换样式键会实时更新。
        </p>
        <div class="preview-shell">
          <div id="templatePreview" class="preview-phone"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const PREVIEW_TEMPLATES = {
  default_article: `
    <div class="preview-statusbar"></div>
    <div class="preview-screen" style="background: linear-gradient(180deg, #f4f7fb 0%, #eef3fa 100%);">
      <div class="preview-meta">公众号预览 · 默认图文模板</div>
      <div class="preview-cover" style="background: linear-gradient(180deg, #111827 0%, #0f172a 58%, #133a8a 100%); padding: 22px 18px; color: #fff;">
        <div style="font-size: 12px; opacity: 0.88; margin-bottom: 6px; letter-spacing: 0.06em;">资讯深读</div>
        <div style="font-size: 22px; line-height: 1.35; font-weight: 700;">千问上线打车能力，可一句话完成个性化需求</div>
      </div>
      <div class="preview-card" style="border-left: 4px solid #1d4ed8;">
        <div style="font-size: 13px; color: #175cd3; font-weight: 700; margin-bottom: 6px;">核心概述</div>
        <div style="font-size: 16px; line-height: 1.72; color: #101828; font-weight: 700;">把复杂信息前置成一段摘要，再用更规整的正文层级承接，整体更像媒体深读稿。</div>
      </div>
      <div class="preview-card" style="margin-top: 12px;">
        <div class="preview-section-title" style="color: #175cd3;">正文结构</div>
        <div style="display: inline-block; background: linear-gradient(90deg, #0f172a 0%, #1856d6 70%, #1da1f2 100%); color: #fff; border-radius: 8px; font-size: 15px; font-weight: 700; padding: 7px 12px; margin-bottom: 10px;">为什么值得关注</div>
        <div class="preview-body-line" style="width: 92%; background: #dbe7fb;"></div>
        <div class="preview-body-line" style="width: 100%; background: #dbe7fb;"></div>
        <div class="preview-body-line" style="width: 84%; background: #dbe7fb;"></div>
        <div style="display: inline-block; background: linear-gradient(90deg, #0f172a 0%, #1856d6 70%, #1da1f2 100%); color: #fff; border-radius: 8px; font-size: 15px; font-weight: 700; padding: 7px 12px; margin: 14px 0 10px;">后续影响</div>
        <div class="preview-body-line" style="width: 96%; background: #dbe7fb;"></div>
        <div class="preview-body-line" style="width: 78%; background: #dbe7fb;"></div>
      </div>
    </div>
  `,
  open_source_infoq: `
    <div class="preview-statusbar"></div>
    <div class="preview-screen" style="background: linear-gradient(180deg, #eff5ff 0%, #f8fbff 100%);">
      <div class="preview-meta">公众号预览 · InfoQ 风开源项目模板</div>
      <div class="preview-cover" style="background: linear-gradient(135deg, #0f4aa3 0%, #2f80ed 100%); padding: 22px 18px; color: #fff;">
        <div style="font-size: 12px; opacity: 0.92; margin-bottom: 6px; letter-spacing: 0.04em;">开源项目解读 · jarrodwatts</div>
        <div style="font-size: 22px; line-height: 1.35; font-weight: 700;">Claude HUD：Claude Code 状态栏插件</div>
      </div>
      <div class="preview-card" style="border-top: 4px solid #2f80ed;">
        <div style="font-size: 13px; color: #175cd3; font-weight: 700; margin-bottom: 6px;">作者视角导语</div>
        <div style="font-size: 18px; line-height: 1.45; color: #101828; font-weight: 700;">面向 Claude Code 的实时状态显示插件</div>
        <div style="font-size: 13px; line-height: 1.7; color: #667085; margin-top: 8px;">Stars 10,783 · Forks 621 · TypeScript</div>
        <div class="preview-section-title" style="color: #175cd3;">核心功能</div>
        <div style="font-size: 14px; line-height: 1.8; color: #344054;">1. 实时展示上下文用量和工具活动</div>
        <div style="font-size: 14px; line-height: 1.8; color: #344054;">2. 分章节介绍适用人群、快速开始和项目亮点</div>
        <div class="preview-section-title" style="color: #175cd3;">正文气质</div>
        <div class="preview-body-line" style="width: 95%; background: #d7e6ff;"></div>
        <div class="preview-body-line" style="width: 88%; background: #d7e6ff;"></div>
        <div class="preview-body-line" style="width: 100%; background: #d7e6ff;"></div>
      </div>
    </div>
  `
};

function renderTemplatePreview() {
  const styleKey = document.getElementById('styleKey').value || 'default_article';
  const previewRoot = document.getElementById('templatePreview');
  previewRoot.innerHTML = PREVIEW_TEMPLATES[styleKey] || PREVIEW_TEMPLATES.default_article;
}

document.getElementById('styleKey').addEventListener('change', renderTemplatePreview);
renderTemplatePreview();

document.getElementById('publishTemplateForm').addEventListener('submit', async function(e) {
  e.preventDefault();

  const formData = new FormData(this);
  const payload = {
    name: formData.get('name'),
    description: formData.get('description'),
    style_key: formData.get('style_key'),
    target_type: formData.get('target_type'),
    is_enabled: document.getElementById('is_enabled').checked,
    is_default: document.getElementById('is_default').checked
  };

  try {
    await apiFetch('<%= isEdit ? `/api/publish-templates/${template.id}` : "/api/publish-templates" %>', {
      method: '<%= isEdit ? "PUT" : "POST" %>',
      body: JSON.stringify(payload)
    });
    showToast('发布样式模板保存成功', 'success');
    setTimeout(() => {
      location.href = '/publish-templates';
    }, 800);
  } catch (error) {
    console.error(error);
  }
});
</script>
